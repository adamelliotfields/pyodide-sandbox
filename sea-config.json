{
  "main": "dist/pyodide.cjs",
  "output": "dist/pyodide",
  "execArgvExtension": "none",
  "execArgv": [
    "--no-warnings",
    "--no-deprecation",
    "--permission",
    "--allow-net",
    "--allow-fs-read=/tmp/*",
    "--allow-fs-write=/tmp/*"
  ],
  "disableExperimentalSEAWarning": true,
  "useCodeCache": false,
  "useSnapshot": false,
  "assets": {
    "pyodide.asm.js": "dist/pyodide.asm.js",
    "pyodide.asm.wasm": "dist/pyodide.asm.wasm",
    "python_stdlib.zip": "dist/python_stdlib.zip"
  }
}
