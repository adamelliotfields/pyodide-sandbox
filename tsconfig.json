{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": ["@tsconfig/node-lts/tsconfig.json"],
  "exclude": ["dist", "node_modules"],
  "compilerOptions": {
    "types": ["*"],
    "noEmit": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true
  }
}
